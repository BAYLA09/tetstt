APP_ENV=production
APP_NAME=Layali Beauty API
API_BASE_URL=https://api.layalibeauty.shop
FRONTEND_URL=https://layalibeauty.shop
DATABASE_URL=postgres://layalibeauty:layalibeauty@layalibeauty_database:5432/layalibeauty?sslmode=disable
FRONTEND_ORIGIN=https://layalibeauty.shop
CORS_ORIGINS=https://layalibeauty.shop,http://localhost:3000
# Sheet leads: set GOOGLE_SHEETS_WEBHOOK_URL (or SHEET_WEBHOOK_URL) to the Apps Script "Web app" URL.
# If empty, orders still save but sheet_sync_status=skipped and nothing hits the sheet.
# If the script uses LAYALI_WEBHOOK_SECRET, set SHEETS_WEBHOOK_SECRET to the same value here
# (then GET /version shows sheet_webhook_secret_configured: true). No leading space after =.
# Example (replace with your Web app /exec URL after Apps Script deploy):
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbzYZi-WeXHFwkF6MALY8lucJBpl8MT3mj-UDuRMELZF3L0oNM0DtrrCuOz2sbF43-F1/exec
SHEET_WEBHOOK_URL=
# No space after = — a leading space breaks the webhook URL in production.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbzYZi-WeXHFwkF6MALY8lucJBpl8MT3mj-UDuRMELZF3L0oNM0DtrrCuOz2sbF43-F1/exec
SHEET_WEBHOOK_SECRET=
SHEETS_WEBHOOK_SECRET=
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v20.0
TIKTOK_PIXEL_ID=
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_API_VERSION=v1.3
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=
ENABLE_CAPT=true
ENABLE_META_CAPT=true
ENABLE_TIKTOK_CAPT=true
ENABLE_SNAP_CAPT=true
MAXMIND_ACCOUNT_ID=1340072
MAXMIND_LICENSE_KEY=
MAXMIND_API_BASE_URL=https://geoip.maxmind.com/geoip/v2.1
ENABLE_IP_FRAUD_CHECK=true
ORDER_ALLOWED_COUNTRY=AE
WHITELISTED_PHONES=+971550603022,0550603022
LOG_LEVEL=INFO

# Admin dashboard (optional). All three required for POST /admin/login and protected routes.
# ADMIN_JWT_SECRET must be at least 16 characters (32+ random hex recommended).
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=
