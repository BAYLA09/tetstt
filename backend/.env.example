# =============================================================================
# Layali Beauty API — قالب env واحد (ما تكرّريش نفس المتغيّر؛ ما مسافة بعد =)
# عوّري القيم السرية عندك فقط فـ EasyPanel، ما تديروش commit.
# =============================================================================

APP_ENV=production
APP_NAME=Layali Beauty API
API_BASE_URL=https://api.layalibeauty.shop

DATABASE_URL=postgres://layalibeauty:CHANGE_ME@layalibeauty_database:5432/layalibeauty?sslmode=disable

FRONTEND_ORIGIN=https://layalibeauty.shop
FRONTEND_URL=https://layalibeauty.shop
CORS_ORIGINS=https://layalibeauty.shop,http://localhost:3000
CORS_ALLOW_WWW=true

# Google Sheet — وحدة من GOOGLE_SHEETS_WEBHOOK_URL أو SHEET_WEBHOOK_URL
GOOGLE_SHEETS_WEBHOOK_URL=
SHEET_WEBHOOK_URL=
# السر لازم يطابق السكربت (ماشي جزء من URL)
SHEETS_WEBHOOK_SECRET=
SHEET_WEBHOOK_SECRET=

META_PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v20.0

TIKTOK_PIXEL_ID=
TIKTOK_PIXEL_CODE=
TIKTOK_ACCESS_TOKEN=
TIKTOK_API_VERSION=v1.3

SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=

# CAPI: لازم true + ما تخليش DISABLE_ORDER_SECURITY_CHECKS=true فالبروود (كيعطل إرسال CAPI)
ENABLE_CAPT=true
ENABLE_META_CAPT=true
ENABLE_TIKTOK_CAPT=true
ENABLE_SNAP_CAPT=true

DISABLE_ORDER_SECURITY_CHECKS=false
ENABLE_IP_FRAUD_CHECK=false
ORDER_ALLOWED_COUNTRY=AE
TRUST_UAE_E164_WITHOUT_GEO=true
WHITELISTED_PHONES=

MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
MAXMIND_API_BASE_URL=https://geoip.maxmind.com/geoip/v2.1

ALLOW_LAMP_BUNDLE_CLIENT_PRICE=true

LOG_LEVEL=INFO

ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=

COMMIT_SHA=
BUILD_TIME_UTC=
PORT=8000
