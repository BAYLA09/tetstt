# الطلبات تُسجّل أولاً في Postgres عبر الباكند (ثم تبان فـ pgweb)، ثم اختيارياً نسخة لـ Google Sheet:
# NEXT_PUBLIC_API_BASE_URL=https://api.layalibeauty.shop
#
# لتعطيل الباكند مؤقتاً (اختبار بدون DB): true
# NEXT_PUBLIC_ORDER_API_DISABLED=true
#
# نسخة اختيارية لـ Google Sheet بعد نجاح الطلب في DB:
# NEXT_PUBLIC_GOOGLE_ORDERS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_ORDER_API_DISABLED=
NEXT_PUBLIC_GOOGLE_ORDERS_WEBHOOK_URL=
